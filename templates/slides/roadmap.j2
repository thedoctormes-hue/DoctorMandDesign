<section class="slide">
  {% set slide = current_slide %}
  {% set loop = current_loop %}
  <div class="mb-sm">
    <span class="section-label text-cyan">{{ current_slide.heading }}</span>
  </div>
  <div class="mb-lg">
    <span style="font-size:22px; font-weight:600; color:var(--yellow);">{{ current_slide.title }}</span>
  </div>
  <div class="flex gap-md mb-lg">
    {% for phase in current_slide.phases %}
    <div class="card-glow" style="flex:1; padding:16px;">
      <div style="font-size:13px; font-weight:700; color:var(--{{ phase.color | default('cyan') }});">{{ phase.label }}</div>
      <div style="font-size:12px; color:var(--text-primary); margin-top:4px;">{{ phase.name }}</div>
      {% if phase.desc %}
      <div class="text-xs" style="color:var(--text-muted); margin-top:2px;">{{ phase.desc }}</div>
      {% endif %}
    </div>
    {% endfor %}
  </div>
  {% if current_slide.segments %}
  <div class="mb-sm">
    <span style="font-size:14px; font-weight:700; color:var(--yellow);">{{ current_slide.segments_title | default('ЦЕЛЕВЫЕ СЕГМЕНТЫ') }}</span>
  </div>
  <div class="flex gap-md">
    {% for seg in current_slide.segments %}
    <div class="feature-card" style="flex:1;">
      <div class="title text-{{ seg.color | default('cyan') }}">{{ seg.title }}</div>
      <div class="desc">{{ seg.desc }}</div>
    </div>
    {% endfor %}
  </div>
  {% endif %}
  <div class="page-number">{{ loop.index }} / {{ current_slides|length }}</div>
</section>
