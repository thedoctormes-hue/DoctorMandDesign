<section class="slide">
  {% set slide = current_slide %}
  {% set loop = current_loop %}
  <div class="mb-md">
    <span class="section-label text-red">{{ slide.heading }}</span>
  </div>
  <div class="mb-sm">
    <span style="font-size:28px; font-weight:700; color:var(--red);">{{ slide.title }}</span>
  </div>
  <div class="mb-lg">
    <span style="font-size:12px; color:var(--text-muted); max-width:80%;">{{ slide.note }}</span>
  </div>
  <div class="flex gap-md mb-lg">
    {% for stat in slide.stat %}
    <div class="stat-card" style="flex:1; border:1px solid var(--border-alert);">
      <div class="number text-{{ stat.color | default('red') }}">{{ stat.value }}</div>
      <div class="label">{{ stat.label }}</div>
    </div>
    {% endfor %}
  </div>
  {% if slide.alert %}
  <div class="card-alert">
    <div style="font-size:14px; font-weight:700; color:var(--yellow);">{{ slide.alert }}</div>
  </div>
  {% endif %}
  <div class="page-number">{{ loop.index }} / {{ current_slides|length }}</div>
</section>
