<section class="slide">
  {% set slide = current_slide %}
  {% set loop = current_loop %}
  <div class="mb-sm">
    <span class="section-label text-cyan">{{ current_slide.heading }}</span>
  </div>
  <div class="mb-lg">
    <span style="font-size:22px; font-weight:700; color:var(--yellow);">{{ current_slide.title }}</span>
  </div>
  <div class="flex gap-md" style="justify-content:center;">
    {% for member in current_slide.members %}
    <div class="card-glow" style="width:200px; text-align:center; padding:20px;">
      <div style="font-size:14px; font-weight:700; color:var(--accent-cyan);">{{ member.name }}</div>
      <div style="font-size:11px; color:var(--text-secondary); margin-top:4px;">{{ member.role }}</div>
    </div>
    {% endfor %}
  </div>
  {% if current_slide.advisors %}
  <div class="mt-lg">
    <div class="flex gap-md" style="justify-content:center;">
      {% for adv in current_slide.advisors %}
      <div class="card" style="width:200px; text-align:center; padding:16px;">
        <div style="font-size:13px; font-weight:700; color:var(--text-primary);">{{ adv.name }}</div>
        <div style="font-size:11px; color:var(--text-muted); margin-top:4px;">{{ adv.role }}</div>
      </div>
      {% endfor %}
    </div>
  </div>
  {% endif %}
  <div class="page-number">{{ loop.index }} / {{ current_slides|length }}</div>
</section>