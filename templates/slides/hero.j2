<section class="slide">
  <div class="flex-col" style="flex:1; justify-content:center; align-items:center; text-align:center;">
    <div style="margin-bottom:8px;">
      <span style="font-size:56px; font-weight:900; color:var(--text-primary); letter-spacing:-0.03em;">{{ current_slide.title }}</span>
    </div>
    <div style="margin-bottom:6px;">
      <span style="font-size:20px; color:var(--accent-cyan);">{{ current_slide.subtitle }}</span>
    </div>
    <div style="margin-bottom:20px;">
      <span style="font-size:12px; color:var(--text-muted);">{{ current_slide.footer }}</span>
    </div>
    {% if current_slide.cards %}
    <div class="flex gap-md" style="justify-content:center; width:100%;">
      {% for card in current_slide.cards %}
      <div class="card-glow" style="width:260px; padding:14px;">
        <div style="font-size:12px; font-weight:700; color:var(--accent-cyan); margin-bottom:4px;">{{ card.title }}</div>
        <div style="font-size:10px; color:var(--text-secondary); line-height:1.4;">{{ card.body }}</div>
      </div>
      {% endfor %}
    </div>
    {% endif %}
  </div>
  <div class="page-number">{{ locale.page_number.replace('{current}', loop.index|string).replace('{total}', current_slides|length|string) }}</div>
</section>
