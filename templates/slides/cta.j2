<section class="slide">
  {% set slide = current_slide %}
  {% set loop = current_loop %}
  <div class="flex-col" style="flex:1; justify-content:center; align-items:center; text-align:center;">
    <div class="mb-sm">
      <span class="section-label text-cyan">{{ current_slide.heading }}</span>
    </div>
    <div class="mb-lg">
      <span style="font-size:32px; font-weight:700;">{{ current_slide.title }}</span>
    </div>
    <div class="flex gap-md mb-lg" style="justify-content:center; flex-wrap:wrap;">
      {% for item in slide["items"] %}
      <div class="card-glow" style="width:220px; text-align:center; padding:16px;">
        <div style="font-size:13px; font-weight:700; color:var(--accent-cyan);">{{ item.title }}</div>
        <div style="font-size:11px; color:var(--text-secondary); margin-top:4px;">{{ item.desc }}</div>
      </div>
      {% endfor %}
    </div>
    {% if current_slide.contact %}
    <div class="card-glow" style="border-color:rgba(57,255,20,0.3); padding:16px 24px;">
      <div style="font-size:14px; font-weight:700; color:var(--green);">{{ current_slide.contact }}</div>
    </div>
    {% endif %}
  </div>
  <div class="page-number">{{ loop.index }} / {{ current_slides|length }}</div>
</section>