<section class="slide">
  {% set slide = current_slide %}
  {% set loop = current_loop %}
  <div class="mb-sm">
    <span class="section-label text-cyan">{{ slide.heading }}</span>
  </div>
  <div class="mb-lg">
    <span style="font-size:22px; font-weight:700; color:var(--text-primary);">{{ slide.title }}</span>
  </div>
  <div class="grid grid-1 gap-md" style="flex:1;">
    {% for item in slide["items"] %}
    <div class="card" style="padding:14px 18px;">
      <div style="font-size:13px; font-weight:700; color:var(--accent-cyan); margin-bottom:4px;">{{ item.question }}</div>
      <div style="font-size:11px; color:var(--text-secondary); line-height:1.5;">{{ item.answer }}</div>
    </div>
    {% endfor %}
  </div>
  <div class="page-number">{{ loop.index }} / {{ current_slides|length }}</div>
</section>
