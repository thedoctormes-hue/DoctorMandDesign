<section class="slide">
  {% set slide = current_slide %}
  {% set loop = current_loop %}
  <div class="flex-col" style="flex:1; justify-content:center; align-items:center; text-align:center;">
    <div class="mb-sm">
      <span class="section-label text-cyan">{{ slide.heading }}</span>
    </div>
    <div class="mb-lg">
      <span style="font-size:28px; font-weight:700;">{{ slide.title }}</span>
    </div>
    <div class="grid grid-2 gap-md mb-lg" style="max-width:500px;">
      <div class="card-glow" style="padding:14px; text-align:left;">
        <div style="font-size:10px; color:var(--text-muted); text-transform:uppercase;">Email</div>
        <div style="font-size:13px; font-weight:600; color:var(--accent-cyan); margin-top:2px;">{{ slide.email }}</div>
      </div>
      <div class="card-glow" style="padding:14px; text-align:left;">
        <div style="font-size:10px; color:var(--text-muted); text-transform:uppercase;">Телефон</div>
        <div style="font-size:13px; font-weight:600; color:var(--accent-cyan); margin-top:2px;">{{ slide.phone }}</div>
      </div>
      <div class="card-glow" style="padding:14px; text-align:left;">
        <div style="font-size:10px; color:var(--text-muted); text-transform:uppercase;">Сайт</div>
        <div style="font-size:13px; font-weight:600; color:var(--accent-cyan); margin-top:2px;">{{ slide.website }}</div>
      </div>
      <div class="card-glow" style="padding:14px; text-align:left;">
        <div style="font-size:10px; color:var(--text-muted); text-transform:uppercase;">Адрес</div>
        <div style="font-size:13px; font-weight:600; color:var(--accent-cyan); margin-top:2px;">{{ slide.address }}</div>
      </div>
    </div>
  </div>
  <div class="page-number">{{ loop.index }} / {{ current_slides|length }}</div>
</section>
