<section class="slide">
  {% set slide = current_slide %}
  {% set loop = current_loop %}
  <div class="flex-col" style="flex:1; justify-content:center; padding:10mm 15mm;">
    <div class="card-glow" style="padding:24px 32px; border-color:var(--border-glow);">
      <div style="font-size:20px; font-weight:400; color:var(--text-primary); line-height:1.6; font-style:italic;">{{ slide.text }}</div>
      <div style="margin-top:16px;">
        <span style="font-size:14px; font-weight:700; color:var(--accent-cyan);">{{ slide.author }}</span>
        {% if slide.role %}
        <span style="font-size:12px; color:var(--text-muted); margin-left:8px;">{{ slide.role }}</span>
        {% endif %}
      </div>
    </div>
  </div>
  <div class="page-number">{{ loop.index }} / {{ current_slides|length }}</div>
</section>